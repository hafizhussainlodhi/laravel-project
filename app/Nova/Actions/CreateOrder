            User::SUPER_ADMINISTRATOR_ROLE,
            User::NTS_ADMINISTRATOR_ROLE,
        ]);
        $buyerId = $isAdmin ? null : ($user->id);

        $area = \App\Models\Area::isActive()->pluck('name', 'id');

        // Admin sees all carriers; buyer sees only non-blocked carriers
        if ($isAdmin) {
            $carriers = \App\Models\Carrier::isActive()->pluck('name', 'id');
        } else {

            // Check if user parent exist
            $user = $request->user();
            $hasParent = $user->parent_user_id ? true : false;

            // feteh parent blocked carrier ids
            $parentBlockedCarrierIds = collect();
            if ($hasParent) {
                $parentBlockedCarrierIds = DB::table('user_carriers')
                    ->where('user_id', $user->parent_user_id)
                    ->where('blocked', true)
                    ->pluck('carrier_id');
            }

            $carriers = \App\Models\Carrier::isActive()
                ->where(function ($query) use ($buyerId) {
                    // Apne blocked carriers exclude karo
                    $query->whereDoesntHave('users', function ($q) use ($buyerId) {
                        $q->where('users.id', $buyerId)
                            ->where('user_carriers.blocked', true);
                    });
                })
                // Parent ke blocked carriers bhi exclude karo
                ->when($parentBlockedCarrierIds->isNotEmpty(), function ($query) use ($parentBlockedCarrierIds) {
                    $query->whereNotIn('id', $parentBlockedCarrierIds);
                })
                ->pluck('name', 'id');
        }

        $fields = [];

        // ── Buyer (admin only) ────────────────────────────────────────────────
        $fields[] = Select::make('Buyer', 'buyer')
            ->options(User::isBuyerRole()->isActive()->pluck('name', 'id'))
