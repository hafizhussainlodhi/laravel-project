class CreateOrder extends Action
{
    use InteractsWithQueue;
    use Queueable;

    protected const MAX_ROWS = 5;

    public function handle(ActionFields $fields, Collection $models)
    {
        $authUser = Auth::user();

        // ── Determine Buyer ───────────────────────────────────────────────────
        $userId = $fields->buyer;
        if ($authUser->role == User::USER_ROLE) {
            $userId = $authUser->id;
        } else if ($authUser->role == User::SELLER_ROLE) {
            $userId = $authUser->id;
        }


        if (!$userId) {
            return Action::danger('User not found.');
        }

        $createdOrders = [];
        $failedRows    = [];

        for ($i = 1; $i <= self::MAX_ROWS; $i++) {

            $carrierId = $fields->{'carrier_' . $i};
            $areaId    = $fields->{'area_' . $i};
            $quantity  = (int) ($fields->{'quantity_' . $i} ?? 0);

            // Both empty — user did not fill this line at all, skip silently
            if (!$carrierId && !$areaId) {
                continue;
            }

            // Partially filled or quantity missing — report error
            if (!$carrierId || !$areaId || $quantity < 1) {
                $failedRows[] = "Line {$i}: Please fill Carrier, Area and Quantity.";
                continue;
            }

            // ── Carrier load ──────────────────────────────────────────────────
            $carrier = \App\Models\Carrier::find($carrierId);

            if (!$carrier) {
                $failedRows[] = "Line {$i}: Carrier not found.";
                continue;
            }

            $defaultCarrierPrice = (float) $carrier->price;

            // ── Buyer carrier rules ───────────────────────────────────────────
            $userCarrier = \App\Models\UserCarrier::where('user_id', $userId)
                ->where('carrier_id', $carrierId)
                ->first(['blocked', 'rate']);

            if (!$userCarrier) {
                $userCarrier = \App\Models\UserCarrier::where('user_id', $authUser->parent_user_id)
                    ->where('carrier_id', $carrierId)
                    ->first(['blocked', 'rate']);
            }

            if ($userCarrier && $userCarrier->blocked) {
                $failedRows[] = "Line {$i}: This carrier is not available for your account.";
                continue;
            }

            // Custom rate > 0 → use it, otherwise carrier default
            $effectiveUnitPrice = ($userCarrier && $userCarrier->rate > 0)
                ? (float) $userCarrier->rate
                : $defaultCarrierPrice;

            // ── Fetch available numbers ───────────────────────────────────────
            // Determine kaun sa admin hai jiske numbers assign hone chahiye
            $numberOwnerUserId = null;
            $buyer = User::find($userId);
            $parent = null;
            if ($buyer) {

                // Case 1: buyer ka parent hai
                if ($buyer->parent_user_id) {

                    $parent = User::find($buyer->parent_user_id);

                    //  NEW CONDITION
                    // agar parent bhi buyer hai (ya self parent case)
                    if (
                        $parent &&
                        (
                            $parent->role === User::USER_ROLE ||
                            $parent->id === $buyer->id
                        )
                    ) {
                        //  super admin ke numbers
                        $superAdmin = User::IsSuperAdminRole()->first();
                        $numberOwnerUserId = $superAdmin?->id;
                    } else {
                        //  seller ke numbers
                        $numberOwnerUserId = $buyer->parent_user_id;
                    }
                } else {
                    //  Case 2: no parent → super admin
                    $superAdmin = User::IsSuperAdminRole()->first();
                    $numberOwnerUserId = $superAdmin?->id;
                }
            }



            $scopeMethod = ($parent?->role == User::SELLER_ROLE) ? 'isSellerNotUsed' : 'isNotUsed';

            $numbers = ModelsNumber::$scopeMethod()
                ->where('carrier_id', $carrierId)
                ->where('area_id', $areaId)
                ->isNotExpired()
                ->where('user_id', $numberOwnerUserId)
                ->orderBy('expiry', 'asc')
                ->limit($quantity)
                ->get();


            $numberIds  = $numbers->pluck('id')->toArray();
            $successQty = count($numberIds);

            // ── Billing (all at buyer's effective price) ──────────────────────
            $subtotal = $successQty * $effectiveUnitPrice;
            $total    = $quantity   * $effectiveUnitPrice;


            // ── Create order ──────────────────────────────────────────────────
            $order              = new Order();
            $order->user_id     = $userId;
            $order->carrier_id  = $carrierId;
            $order->city_id     = null;
            $order->area_id     = $areaId;
            $order->price       = $effectiveUnitPrice;
            $order->order_type  = Order::ORDER_TYPE_BUY;
            $order->total_qty   = $quantity;
            $order->success_qty = $successQty;
            $order->subtotal    = $subtotal;
            $order->total       = $total;
            $order->status      = ($successQty === $quantity)
                ? Order::STATUS_COMPLETED
                : Order::STATUS_PENDING;

            $order->save();

            // ── Assign numbers ────────────────────────────────────────────────
            if ($successQty > 0) {
                $order->numbers()->sync($numberIds);
                if ($parent && $parent->id == $numberOwnerUserId) {
                    ModelsNumber::whereIn('id', $numberIds)->update(['seller_is_used' => true]);
                } else {
                    if ($buyer->role != User::USER_ROLE) {
                        ModelsNumber::whereIn('id', $numberIds)->update([
                            'user_id' => $buyer->id,
                            'is_used' => true
                        ]);

                        AutoAssignNumbers::dispatch();
                    }

                    ModelsNumber::whereIn('id', $numberIds)->update(['is_used' => true]);
                }
            }

            $createdOrders[] = $order;
        }

        // ── No line was filled at all ─────────────────────────────────────────
        if (empty($createdOrders) && empty($failedRows)) {
            return Action::danger('Please fill at least one order line.');
        }


        // ── Notifications (only when a buyer places the order) ────────────────
        if ($authUser->role == User::USER_ROLE || $authUser->role == User::SELLER_ROLE && count($createdOrders) > 0) {

            $superAdmin = User::IsSuperAdminRole()->first();

            if ($superAdmin) {
                $count = count($createdOrders);
                $superAdmin->notify(
                    NovaNotification::make()
                        ->message("{$count} new order(s) created by " . $authUser->name)
                        ->action('View Orders', NovaURL::remote('/dashboard/resources/orders'))
                        ->icon('info')
                        ->type('success')
                );

                foreach ($createdOrders as $createdOrder) {
                    try {
                        Mail::send(new NewOrderNotification(
                            config('app.url') . '/dashboard/resources/orders/' . $createdOrder->id
                        ));
                    } catch (\Exception $e) {
                        Log::error('Order email error: ' . $e->getMessage());
                    }
                }
            }
        }

        // ── Final response ────────────────────────────────────────────────────
        if (empty($createdOrders)) {
            return Action::danger('No order was created. ' . implode(' | ', $failedRows));
        }

        $msg = count($createdOrders) . ' order created successfully.';
        if (!empty($failedRows)) {
            $msg .= ' Skipped: ' . implode(' | ', $failedRows);
        }

        return Action::message($msg);
    }

    public function fields(NovaRequest $request): array
    {
        $user    = $request->user();
